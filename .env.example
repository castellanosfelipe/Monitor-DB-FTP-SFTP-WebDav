# StabilityMonitor — Modo B (Docker Compose)
# Copia este archivo a `.env` y completa los valores.

# OBLIGATORIO — clave de cifrado de secretos (Fernet).
# Génerala con:  docker compose run --rm monitor python -m app.keygen
#   (o en cualquier Python:  python -m app.keygen)
# ⚠ Guárdala en un lugar seguro: sin esta clave, las contraseñas almacenadas
#   en data/monitor.db son IRRECUPERABLES por diseño.
MONITOR_SECRET_KEY=

# OBLIGATORIO — credenciales del dashboard (HTTP Basic).
# En este modo el dashboard escucha en 0.0.0.0 y SIEMPRE exige autenticación.
# ⚠ Si lo expones fuera de una red interna, ponlo detrás de un reverse proxy
#   con TLS (nginx/caddy/traefik): Basic Auth sin TLS viaja en claro.
MONITOR_DASH_USER=admin
MONITOR_DASH_PASS=

# Zona horaria del contenedor (los datos se guardan siempre en UTC).
TZ=America/Mexico_City

# Opcional — puerto interno (el mapeo se hace en docker-compose.yml).
# MONITOR_PORT=8090

# Opcional — sembrar datos de demostración en el primer arranque.
# MONITOR_DEMO=1

# El SMTP y el webhook de alertas se configuran desde el dashboard
# (⚙ Ajustes), no por variables de entorno.
